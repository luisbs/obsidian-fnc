{
  "private": true,
  "license": "MIT",
  "version": "0.1.3",
  "name": "obsidian-fnc",
  "description": "Common obsidian utility functions",
  "keywords": [
    "obsidian",
    "utility"
  ],
  "author": {
    "name": "luisbs",
    "url": "https://github.com/luisbs"
  },
  "type": "module",
  "main": "./lib/obsidian-fnc.cjs",
  "module": "./lib/obsidian-fnc.js",
  "types": "./types/index.d.ts",
  "files": [
    "lib",
    "types"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -emitDeclarationOnly -skipLibCheck",
    "prepare": "npx simple-git-hooks",
    "test": "jest",
    "lint": "run-s lint:ts lint:eslint lint:prettier",
    "lint:ts": "tsc -noEmit -skipLibCheck",
    "lint:prettier": "prettier --check \"./src/**/*.(js|ts)\"",
    "lint:prettier:fix": "prettier --write \"./src/**/*.(js|ts)\"",
    "lint:eslint": "eslint --ext .js,.ts ./src",
    "lint:eslint:fix": "eslint --fix --ext .js,.ts ./src"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.10",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "builtin-modules": "^3.3.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.7",
    "npm-run-all": "^4.1.5",
    "obsidian": "1.5.7-1",
    "prettier": "^3.3.2",
    "simple-git-hooks": "^2.11.1",
    "ts-jest": "^29.1.5",
    "tslib": "^2.6.3",
    "typescript": "^5.5.3",
    "vite": "^5.3.3"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.6.7"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged",
    "commit-msg": "npx commitlint -e -V"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
